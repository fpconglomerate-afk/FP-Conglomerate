# Copy this file to `admin/.env` and fill in values. Vite loads `.env` from this folder.
# Do not commit `admin/.env` — it is gitignored.

# --- API (Elevate) ---
#
# RECOMMENDED (avoids CORS in the browser):
#   Leave VITE_PUBLIC_API_BASE_URL empty. The app calls /v1 on this admin origin only.
#   - Local dev: Vite proxies /v1 → API (see admin/vite.config.ts, VITE_ELEVATE_DEV_PROXY_URL).
#   - Vercel: admin/vercel.json rewrites /v1/* to Render — no CORS to Render needed.
#
# OPTIONAL (direct calls to Render — requires CORS_ORIGINS on the API for this admin origin):
#   VITE_PUBLIC_API_BASE_URL=https://elevate-backend-vpo3.onrender.com
#
VITE_PUBLIC_API_BASE_URL=

# Override proxy target in local dev only (when VITE_PUBLIC_API_BASE_URL is empty):
# VITE_ELEVATE_DEV_PROXY_URL=https://elevate-backend-vpo3.onrender.com

# Recommended in production: set your tenant organization slug so staff sign-in is prefilled.
# This value should match `organizations.slug` in Elevate.
VITE_PUBLIC_ORGANIZATION_SLUG=

# Optional: used for “Back to site” when there is no browser history (no trailing slash).
# VITE_PUBLIC_SITE_URL=https://www.yourdomain.com
