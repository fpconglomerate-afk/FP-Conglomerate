# Copy this file to `admin/.env` and fill in values. Vite loads `.env` from this folder.
# Do not commit `admin/.env` — it is gitignored.

# --- Required: same API as the marketing site ---
VITE_PUBLIC_API_BASE_URL=

# Optional: pre-fills the staff login “Organization slug” field (from API seed / your tenant).
VITE_PUBLIC_ORGANIZATION_SLUG=

# Optional: used for “Back to site” when there is no browser history (no trailing slash).
# VITE_PUBLIC_SITE_URL=https://www.yourdomain.com
