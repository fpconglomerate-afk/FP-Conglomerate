# Copy this file to `frontend/.env` and fill in values. Vite loads `.env` from this folder.
# Do not commit `frontend/.env` — it is gitignored.

# --- Required: Elevate Central API (deploy separately; see docs/DEPLOYMENT.md) ---
#
# Option A — Same-origin /v1 proxy (recommended for production on Vercel or Netlify):
#   Leave VITE_PUBLIC_API_BASE_URL unset or empty. The app calls /v1 on your domain; hosting
#   proxies to Render (see frontend/vercel.json and public/_redirects). No CORS setup on Render.
#
# Option B — Call the API directly from the browser:
#   VITE_PUBLIC_API_BASE_URL=https://your-api.onrender.com
#   You MUST add your site origin to CORS_ORIGINS on the API (e.g. https://www.fpconglomerate.com).
#
# Optional: force-disable relative mode: VITE_PUBLIC_API_RELATIVE=false
#
VITE_PUBLIC_API_BASE_URL=
# When RELATIVE=true in local dev, Vite proxies /v1 → Render (override URL if needed):
# VITE_ELEVATE_DEV_PROXY_URL=https://elevate-backend-vpo3.onrender.com

# Publishable site key (raw key shown when you run `npm run seed` on the API, or from ops).
# Sent as header X-Site-Key on POST /v1/public/leads — NOT a JWT secret.
VITE_PUBLIC_SITE_KEY=

# Recommended in production: organization slug (same as organizations.slug in the API) for live marketing CMS.
# Use the same slug configured in `admin/.env` so admin edits and public reads target the same tenant.
# When set, blog, careers, and portfolio pages call GET /v1/public/org/:slug/... first (no site key, no JWT).
# If unset or the request fails, the app falls back to local SiteContent / bundled copy.
VITE_PUBLIC_ORGANIZATION_SLUG=

# Lead payload — industryVertical MUST be one of:
# construction | real_estate | ngo | hospital | marketing | other
VITE_PUBLIC_LEAD_INDUSTRY_VERTICAL=marketing
VITE_PUBLIC_LEAD_SOURCE_SYSTEM=marketing-site
VITE_PUBLIC_LEAD_FORM_ID=contact-main

# --- Optional: URLs (set in production for SEO and footer links) ---
# Canonical site URL for sitemap/OG (no trailing slash). Set on Vercel/Netlify for production builds.
# VITE_SITE_URL=https://www.yourdomain.com

# Optional legacy: unused by the app (admin is not linked from the marketing footer).
# VITE_ADMIN_URL=https://admin.yourdomain.com
